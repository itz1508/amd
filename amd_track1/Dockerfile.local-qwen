# AMD Track 1 General-Purpose AI Agent - Local Qwen Variant
# Multi-stage build for minimal image size with embedded Qwen model

# Stage 1: Build stage
FROM python:3.11-slim as builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    ca-certificates \
    git \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY amd_track1/requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --user -r requirements.txt

# Stage 2: Runtime stage
FROM python:3.11-slim

WORKDIR /app

# Install llama.cpp server for local model inference
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    tar \
    gzip \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/* \
    && curl -L -o /tmp/llama-bin-ubuntu-x64.tar.gz \
       https://github.com/ggml-org/llama.cpp/releases/download/b9956/llama-b9956-bin-ubuntu-x64.tar.gz \
    && mkdir -p /opt/llama \
    && tar -xzf /tmp/llama-bin-ubuntu-x64.tar.gz -C /opt/llama \
    && find /opt/llama -type f -name llama-server -exec chmod +x {} \; \
    && find /opt/llama -type f -name llama-server -exec ln -sf {} /usr/local/bin/llama-server \; \
    && find /opt/llama -type d \( -name lib -o -name bin \) > /etc/ld.so.conf.d/llama.conf \
    && ldconfig \
    && rm -f /tmp/llama-bin-ubuntu-x64.tar.gz

# Copy Python packages from builder
COPY --from=builder /root/.local /root/.local
ENV PATH=/root/.local/bin:$PATH

# Create directories for input/output/models
RUN mkdir -p /input /output /models && \
    chmod 755 /input /output /models

# Copy application code and wrapper
COPY amd_track1 /app/amd_track1
COPY amd_track1/start_local_agent.py /app/start_local_agent.py

# The model is supplied at runtime through LOCAL_MODEL_PATH.

# Runtime settings are injected by the caller; no model, endpoint, path, or
# mode is baked into this experimental image.
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

# Run the package from its parent so relative imports resolve correctly.
WORKDIR /app

# Entry point - wrapper starts llama-server then runs agent
ENTRYPOINT ["python3", "/app/start_local_agent.py"]

# Expose port for llama.cpp server
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
    CMD python3 -c "import sys; sys.exit(0)" || exit 1
